---
import { Tab, TabsList, TabsPanel, TabsRoot } from '@/components/Tabs.tsx';

/**
 * Frame for standalone fenced code blocks: filename/language header + copy
 * button, reusing the shared `Tabs` chrome. Injected by the `satteriCodeFrame`
 * MDAST plugin, which wraps each standalone code block in `<CodeFrame>`. The
 * slot is the Shiki-highlighted `<pre>` (raw HTML under the Sätteri pipeline).
 *
 * Code blocks inside an authored `<TabsPanel>` are not wrapped — the tab group
 * already provides their frame.
 */
interface Props {
  title?: string;
  lang?: string;
}

const { title, lang } = Astro.props;
const label = title || lang || 'code';
const value = 'code';
---

<TabsRoot client:idle>
  <TabsList client:idle label={`${label} code`}>
    <Tab client:idle value={value} initial>{label}</Tab>
  </TabsList>
  <TabsPanel client:idle value={value} initial>
    <slot />
  </TabsPanel>
</TabsRoot>
