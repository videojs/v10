---

import type { HTMLTag, Polymorphic } from 'astro/types';
import { clsx } from 'clsx';
import { twMerge } from 'tailwind-merge';

type Props<Tag extends HTMLTag = 'h3'> = Polymorphic<{ as: Tag }> & {
  maxWidth?: boolean;
  class?: string;
};

const { as: Tag = 'h3', maxWidth = true, class: className, ...props } = Astro.props;
---

<Tag
  class={twMerge(
    clsx(
      "text-display-h2 mt-12 mb-6 font-display-extended",
      maxWidth && "mx-auto max-w-3xl",
    ),
    className,
  )}
  {...props}
>
  <slot />
</Tag>
