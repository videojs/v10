---

import type { HTMLTag, Polymorphic } from 'astro/types';
import { clsx } from 'clsx';
import { twMerge } from '@/utils/twMerge';

type Props<Tag extends HTMLTag = 'h2'> = Polymorphic<{ as: Tag }> & {
  maxWidth?: boolean;
  class?: string;
};

const { as: Tag = 'h2', maxWidth = true, class: className, ...props } = Astro.props;
---

<Tag
  class={twMerge(
    clsx(
      "mt-16 mb-8 font-display text-h3 leading-tight uppercase @lg:text-h25",
      maxWidth && "mx-auto max-w-3xl",
    ),
    className,
  )}
  {...props}
>
  <slot />
</Tag>
