---

import type { HTMLTag, Polymorphic } from 'astro/types';
import { clsx } from 'clsx';
import { twMerge } from '@/utils/twMerge';

type Props<Tag extends HTMLTag = 'h4'> = Polymorphic<{ as: Tag }> & {
  maxWidth?: boolean;
  class?: string;
};

const { as: Tag = 'h4', maxWidth = true, class: className, ...props } = Astro.props;
---

<Tag
  class={twMerge(
    clsx("mt-8 mb-4 text-p15 font-bold", maxWidth && "mx-auto max-w-3xl"),
    className,
  )}
  {...props}
>
  <slot />
</Tag>
