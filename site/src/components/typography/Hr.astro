---

import type { HTMLTag, Polymorphic } from 'astro/types';
import { clsx } from 'clsx';
import { twMerge } from '@/utils/twMerge';

type Props<Tag extends HTMLTag = 'hr'> = Polymorphic<{ as: Tag }> & {
  maxWidth?: boolean;
  class?: string;
};

const { as: Tag = 'hr', maxWidth = true, class: className, ...props } = Astro.props;
---

<Tag
  class={twMerge(
    clsx(
      "border-light-40 my-12 border-t",
      maxWidth && "mx-auto max-w-3xl",
    ) /* TODO(old-color): light-40 */,
    className,
  )}
  {...props}
/>
