---

import type { HTMLTag, Polymorphic } from 'astro/types';
import { clsx } from 'clsx';
import { twMerge } from 'tailwind-merge';

type Props<Tag extends HTMLTag = 'blockquote'> = Polymorphic<{ as: Tag }> & {
  maxWidth?: boolean;
  class?: string;
};

const { as: Tag = 'blockquote', maxWidth = true, class: className, ...props } = Astro.props;
---

<Tag
  class={twMerge(
    clsx(
      "my-12 border-l border-light-40 pl-6",
      "[&>*:last-child]:!mb-0 [&>.my-12]:my-4 [&>.my-6]:my-2",
      maxWidth && "mx-auto max-w-3xl",
    ),
    className,
  )}
  {...props}
>
  <slot />
</Tag>
