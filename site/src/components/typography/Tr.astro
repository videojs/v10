---

import type { HTMLTag, Polymorphic } from 'astro/types';
import { twMerge } from '@/utils/twMerge';

type Props<Tag extends HTMLTag = 'tr'> = Polymorphic<{ as: Tag }> & {
  class?: string;
};

const { as: Tag = 'tr', class: className, ...props } = Astro.props;
---

<Tag
  class={twMerge(
    "border-b border-manila-dark dark:border-warm-gray",
    className,
  )}
  {...props}
>
  <slot />
</Tag>
