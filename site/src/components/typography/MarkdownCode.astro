---
import type { HTMLTag, Polymorphic } from 'astro/types';
import { twMerge } from '@/utils/twMerge';

import { shared } from './styles';

type Props<Tag extends HTMLTag = 'code'> = Polymorphic<{ as: Tag }> & {
  class?: string;
  codeBlock?: string;
};

const { as: Tag = 'code', class: className, codeBlock, ...props } = Astro.props;

// When codeBlock="true", Shiki handles styling; otherwise style as inline code.
// Compute the class here rather than branching in the template: the Astro 7
// compiler preserves whitespace around an own-line <slot />, which leaks into
// inline code and <pre>. Keeping <slot /> tight against the tags avoids it, and
// a single root element (vs a templated ternary) survives prettier, which would
// otherwise re-expand the slot onto its own line.
const isCodeBlock = codeBlock === 'true';
const codeClass = twMerge(isCodeBlock ? shared.codeBlock : shared.code, className);
---

<Tag class={codeClass} {...props}><slot /></Tag>
