---
import type { HTMLAttributes } from 'astro/types';
import CodeFrame from './CodeFrame.astro';

type Props = HTMLAttributes<'pre'> & {
  maxWidth?: boolean;
  hasFrame?: boolean;
};

const { maxWidth = false, class: className, style: _style, title, hasFrame, ...props } = Astro.props;

const language = props['data-language'];
const label = title || language || 'code';
---

{
  /* Single root element, no templated ternary: this keeps the <pre>'s <slot />
   inline through prettier so the Astro 7 compiler doesn't leak whitespace into
   the code block. The optional tab chrome lives in CodeFrame. */
}
<CodeFrame framed={!hasFrame} label={label}
  ><pre class={className} {...props}><slot /></pre></CodeFrame
>
