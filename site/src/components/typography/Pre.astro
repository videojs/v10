---

import type { HTMLTag, Polymorphic } from 'astro/types';
import { Tab, TabsList, TabsPanel, TabsRoot } from '@/components/Tabs.tsx';

type Props<Tag extends HTMLTag = 'pre'> = Polymorphic<{ as: Tag }> & {
  maxWidth?: boolean;
  class?: string;
  hasFrame?: boolean;
  title?: string;
};

const { as: Tag = 'pre', maxWidth = false, class: className, style: _style, title, hasFrame, ...props } = Astro.props;

const language = props['data-language'];
const label = title || language || 'code';

const value = 'code';
---

{
  hasFrame ? (
    <Tag class={className} {...props}>
      <slot />
    </Tag>
  ) : (
    <TabsRoot variant="docs" client:visible>
      <TabsList client:visible label={`${label} code`} variant="docs">
        <Tab client:visible value={value} initial variant="docs">
          {label}
        </Tab>
      </TabsList>
      <TabsPanel client:visible value={value} initial variant="docs">
        <Tag class={className} {...props}>
          <slot />
        </Tag>
      </TabsPanel>
    </TabsRoot>
  )
}
