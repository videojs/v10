---
import clsx from 'clsx';
import Check from '../icons/check.svg?react';

const milestones = [
  {
    date: 'Oct 2025',
    title: 'Tech Preview',
    description: 'Kick the tires, and light the fires',
    completed: true,
  },
  {
    date: 'Mar 2026',
    title: 'Beta',
    description: 'Close to stable. Experimental adoption in real projects',
    completed: true,
  },
  {
    date: 'Mid 2026',
    title: 'GA',
    description: 'Stable APIs. Feature parity w/ Media Chrome, Vidstack, Plyr.',
    completed: false,
  },
  {
    date: 'End of 2026',
    title: 'Core Feature Parity',
    description: 'Video.js core/contrib plugins migrated',
    completed: false,
  },
];
---

<section class="mx-auto w-full max-w-305 px-5">
  <header
    class="mb-12 border-t border-b border-y-faded-black py-4 dark:border-y-light-manila"
  >
    <h2
      class="text-center font-display-extended text-h2 font-bold text-faded-black uppercase dark:text-light-manila"
    >
      Roadmap
    </h2>
  </header>

  <div class="relative mb-20 h-full lg:mb-30">
    <div class="relative grid gap-15 md:grid-cols-4 md:gap-8 lg:gap-12">
      {
        milestones.map((milestone) => (
          <div class="relative flex gap-12 text-left md:flex-col md:items-center md:gap-0 md:text-center">
            <p class="relative z-10 hidden pb-4 font-display-extended text-h4 font-bold text-faded-black uppercase md:block dark:text-light-manila">
              {milestone.date}
            </p>
            <div class="relative flex w-auto justify-center py-0.5 md:w-full">
              <div
                class={clsx(
                  "relative z-10 flex h-10 w-10 items-center justify-center rounded-full border bg-light-manila dark:bg-faded-black",
                  milestone.completed ? "border-orange" : "border-dark-manila",
                )}
              >
                {milestone.completed && (
                  <Check width={"1.03rem"} className="text-orange" />
                )}
              </div>
            </div>
            <div>
              <p class="tracking-wider relative z-10 block font-display-extended text-h3 font-bold text-faded-black uppercase md:hidden dark:text-light-manila">
                {milestone.date}
              </p>
              <h3 class="font-display-extended text-h3 leading-none font-bold text-orange uppercase md:mt-5 md:px-1 lg:text-h2">
                {milestone.title}
              </h3>
              <p class="mt-2.5 max-w-55 text-p2 text-warm-gray md:mx-auto dark:text-light-manila">
                {milestone.description}
              </p>
            </div>
          </div>
        ))
      }
      <div class="absolute left-0 mt-5 hidden w-full md:block">
        <div
          class="data-bar absolute top-3 left-0 z-0 h-8 w-full brightness-50 dark:brightness-100"
        >
        </div>
        <div
          class="data-bar data-bar-orange absolute top-3 left-0 z-2 h-8 bg-light-manila dark:bg-faded-black"
          style="max-width: 37.5%"
        >
        </div>
        <div
          class="absolute top-3 left-0 z-3 h-10 w-50 bg-linear-to-r from-light-manila to-transparent dark:from-faded-black"
        >
        </div>
        <div
          class="absolute top-3 right-0 z-4 h-10 w-50 bg-linear-to-r from-transparent to-light-manila dark:to-faded-black"
        >
        </div>
      </div>
      <div class="absolute top-0 left-0 mt-0 block h-full w-10 md:hidden">
        <div
          class="horizontal-bars absolute top-0 left-0 z-0 h-8 w-full brightness-50 dark:brightness-100"
        >
        </div>
        <div
          class="horizontal-bars horizontal-bars-orange absolute top-0 left-0 z-2 h-10 bg-light-manila dark:bg-faded-black"
          style="max-height: 30%"
        >
        </div>
        <div
          class="absolute right-0 bottom-0 z-4 h-50 w-10 bg-linear-to-b from-transparent to-light-manila dark:to-faded-black"
        >
        </div>
        <div
          class="absolute top-0 right-0 z-4 h-20 w-10 bg-linear-to-b from-light-manila to-transparent dark:from-faded-black"
        >
        </div>
      </div>
    </div>
  </div>
</section>
