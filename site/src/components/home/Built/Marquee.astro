---
import TriangleArrow from '../../icons/triangle-arrow.svg?react';

const REPEAT_COUNT = 4;
const items = Array.from({ length: REPEAT_COUNT });
---
<div
  class="col-span-full overflow-hidden py-8 border-b border-b-dark-manila relative z-1"
  aria-label="Streaming bits on millions of sites"
  role="marquee"
>
  <div
    id="logos"
    class="flex whitespace-nowrap animate-marquee text-h5 font-display-extended uppercase text-light-manila"
  >
    {[...items, ...items].map(() => (
      <span class="inline-flex items-center gap-7 shrink-0 pr-7">
        <span>Streaming bits on millions of sites</span>
        <TriangleArrow width="0.75rem" />
      </span>
    ))}
  </div>
</div>
