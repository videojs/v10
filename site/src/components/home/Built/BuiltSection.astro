---
import DataViz from './DataViz.astro';
import Intro from './Intro.astro';
import SocialProof from './SocialProof.astro';
---
<section class="flex flex-col bg-faded-black dark:bg-warm-gray relative mb-32.5 lg:mb-40">
  <div class="absolute inset-0 built-bg-gray dark:built-bg-black z-0"></div>
    <header class="relative w-full max-w-305 mx-auto px-10 h-27.5 md:h-20.5 -mt-13.5 md:-mt-10 flex flex-col justify-center items-center text-center mb-5">
      <div class="absolute z-0 top-0 bottom-0 left-5 right-5 grid rounded-xs overflow-hidden" style="grid-template-rows: 1fr auto 1fr">
        <div class="bg-gold"></div>
        <div class="h-0.5 bg-faded-black"></div>
        <div class="bg-orange"></div>
      </div>
      <h2 class="relative inline p-2.5 text-h2 rounded-xs bg-faded-black text-center text-light-manila font-display-extended uppercase font-bold">
        v10 is built different
      </h2>
    </header>
    <div class="relative w-full max-w-305 mx-auto px-5 grid grid-cols-1 md:grid-cols-2 auto-rows-auto gap-5">
      <Intro />
      <DataViz />
      <SocialProof />
    </div>
</section>
