---
import clsx from 'clsx';

const seconds = [0, 5, 10, 15, 20];
---

<div
  class="rounded-xs border border-dark-manila bg-faded-black p-5 md:p-10 lg:p-15"
>
  <header class="text-p2">
    <h3 class="font-bold text-light-manila">Download speeds</h3>
    <span class="whitespace-nowrap text-dark-manila"
      >(based on slow 4G connection)</span
    >
  </header>
  <p
    class="mt-6 inline-block items-center rounded-full border border-light-manila bg-faded-black px-8 py-0.5 text-center font-display-extended text-h5 font-bold text-light-manila uppercase md:hidden"
  >
    VJS 8
  </p>
  <div class="data-bar mt-4 mb-2 w-full md:mt-5 md:mb-2.5"></div>
  <div class="flex items-center gap-2.5">
    <p
      class="hidden min-w-30 items-center justify-center rounded-full border border-light-manila bg-faded-black py-0.5 text-center font-display-extended text-h5 font-bold text-light-manila uppercase md:flex"
    >
      VJS 8
    </p>
    <p
      class="flex gap-1 text-center font-display-extended text-h5 text-light-manila uppercase lg:gap-2.5"
    >
      <span class="font-bold">3.96s</span>
      <span>/</span>
      <span class="whitespace-nowrap">722 KB</span>
    </p>
  </div>
  <p
    class="mt-6 inline-block items-center rounded-full border border-orange bg-faded-black px-8 py-0.5 text-center font-display-extended text-h5 font-bold text-orange uppercase md:hidden"
  >
    VJS 10
  </p>
  <div
    class="data-bar data-bar-orange mt-4 mb-2 md:mt-5 md:mb-2.5"
    style="max-width: 32.25%"
  >
  </div>

  <div class="flex items-center gap-2.5">
    <p
      class="hidden min-w-30 items-center justify-center rounded-full border border-orange bg-faded-black py-0 text-center font-display-extended text-h5 font-bold text-orange uppercase md:flex"
    >
      VJS 10
    </p>
    <p
      class="2xl flex gap-1 text-center font-display-extended text-h5 text-orange uppercase lg:gap-2.5"
    >
      <span class="font-bold">1.29s</span>
      <span>/</span>
      <span class="whitespace-nowrap">198 KB</span>
    </p>
  </div>

  <div class="flex w-full justify-between px-1 pt-4 pb-2">
    {
      Array.from({ length: 21 }, (_, i) => (
        <div
          class={clsx(
            "h-4 w-px",
            seconds.includes(i) ? "bg-light-manila" : "bg-warm-gray",
          )}
        />
      ))
    }
  </div>
  <div class="-mx-1.5 flex justify-between" style="width: calc(100% + 0.85rem)">
    {
      Array.from({ length: 5 }, (_, i) => (
        <div class="w-5 text-center text-p3 text-light-manila">{i}s</div>
      ))
    }
  </div>
</div>
