---
import { LEGACY_BANNER_DISMISS_KEY } from '@/consts';
---

<script is:inline define:vars={{ bannerKey: LEGACY_BANNER_DISMISS_KEY }}>
  if (typeof localStorage !== "undefined" && typeof document !== "undefined") {
    if (localStorage[bannerKey] === "true") {
      document.documentElement.classList.add("legacy-banner-dismissed");
    }
  }
</script>
