---
import Footer from '@/components/Footer.astro';
import NavBar from '@/components/NavBar/NavBar.astro';
import Base from '@/layouts/Base.astro';
---

<Base
  title="Hover Style Proposals"
  description="Brainstorming retro hover styles for text links — 80s/90s VHS vibe."
>
  <NavBar />
  <main class="mx-auto w-full max-w-200 px-5 pt-10 pb-20 md:pt-20">
    <header class="mb-12 border-y border-faded-black py-4 dark:border-manila-light">
      <h1 class="text-center font-display text-h2 text-faded-black uppercase dark:text-manila-light">
        Hover Style Proposals
      </h1>
      <p class="mt-4 text-center text-p2 text-warm-gray dark:text-manila-dark">
        Issue #810 — Text link hover states. Hover/focus each link to see the effect.
      </p>
    </header>

    <div class="space-y-16">
      <!-- Current (broken) -->
      <section>
        <h2 class="mb-2 font-display text-h3 uppercase text-faded-black dark:text-manila-light">
          0. Current (underline disappears)
        </h2>
        <p class="mb-4 text-p3 text-warm-gray dark:text-manila-dark">
          The existing style. Underline removes on hover — loses affordance.
        </p>
        <p class="text-p2">
          Read the <a href="#" class="hover-current">full release notes</a> for more details
          about <a href="#" class="hover-current">what's changed</a> in this version.
        </p>
      </section>

      <!-- 1. Underline Color Shift -->
      <section>
        <h2 class="mb-2 font-display text-h3 uppercase text-faded-black dark:text-manila-light">
          1. Underline Color Shift
        </h2>
        <p class="mb-4 text-p3 text-warm-gray dark:text-manila-dark">
          Underline stays, but shifts to an accent color (gold). Simple, accessible, clear feedback.
        </p>
        <p class="text-p2">
          Read the <a href="#" class="hover-color-shift">full release notes</a> for more details
          about <a href="#" class="hover-color-shift">what's changed</a> in this version.
        </p>
      </section>

      <!-- 2. Color Inversion -->
      <section>
        <h2 class="mb-2 font-display text-h3 uppercase text-faded-black dark:text-manila-light">
          2. Color Inversion / Negative
        </h2>
        <p class="mb-4 text-p3 text-warm-gray dark:text-manila-dark">
          Swap foreground/background like teletext or terminal selection. Bold and unmistakable.
        </p>
        <p class="text-p2">
          Read the <a href="#" class="hover-inversion">full release notes</a> for more details
          about <a href="#" class="hover-inversion">what's changed</a> in this version.
        </p>
      </section>

      <!-- 3. VHS Chromatic Aberration -->
      <section>
        <h2 class="mb-2 font-display text-h3 uppercase text-faded-black dark:text-manila-light">
          3. Chromatic Aberration
        </h2>
        <p class="mb-4 text-p3 text-warm-gray dark:text-manila-dark">
          Cyan + magenta text-shadow offset like bad VHS tracking. Maximum retro energy.
        </p>
        <p class="text-p2">
          Read the <a href="#" class="hover-vhs-glitch">full release notes</a> for more details
          about <a href="#" class="hover-vhs-glitch">what's changed</a> in this version.
        </p>
      </section>
    </div>
  </main>
  <Footer />
</Base>

<style>
  /* Shared base for all demo links */
  section a {
    text-underline-offset: 0.25em;
    text-decoration-thickness: max(0.05em, 0.05rem);
  }

  /* 0. Current (the problem) */
  .hover-current {
    text-decoration: underline;
  }
  .hover-current:hover,
  .hover-current:focus-visible {
    text-decoration: none;
  }

  /* 1. Underline Color Shift — instant */
  .hover-color-shift {
    text-decoration: underline;
  }
  .hover-color-shift:hover,
  .hover-color-shift:focus-visible {
    text-decoration-color: var(--color-gold);
  }

  /* 2. Color Inversion — instant */
  .hover-inversion {
    text-decoration: underline;
    padding: 0.05em 0.15em;
    margin: -0.05em -0.15em;
  }
  .hover-inversion:hover,
  .hover-inversion:focus-visible {
    background-color: var(--color-faded-black);
    color: var(--color-manila-light);
    text-decoration: none;
  }
  :global(.dark) .hover-inversion:hover,
  :global(.dark) .hover-inversion:focus-visible {
    background-color: var(--color-manila-light);
    color: var(--color-faded-black);
  }

  /* 3. Chromatic Aberration — short transition */
  .hover-vhs-glitch {
    text-decoration: underline;
    transition: text-shadow 0.15s ease;
  }
  .hover-vhs-glitch:hover,
  .hover-vhs-glitch:focus-visible {
    text-shadow: 1.5px 0 var(--color-magenta), -1.5px 0 cyan;
  }
</style>
