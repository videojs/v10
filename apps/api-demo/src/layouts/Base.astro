---
import ThemeInit from '../components/ThemeInit.astro';
import { ThemeToggle } from '../components/ThemeToggle';
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = '' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#f3e7d2" />
    <title>{title}</title>
    {description && <meta name="description" content={description} />}

    {/* Faster video / poster loading from Mux. */}
    <link rel="preconnect" href="https://stream.mux.com" crossorigin />
    <link rel="preconnect" href="https://image.mux.com" crossorigin />
    <link rel="preconnect" href="https://static.mux.com" crossorigin />

    {/* Fonts: match videojs.org (Instrument Sans + IBM Plex Mono). */}
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=Instrument+Sans:ital,wght@0,400..600;1,400..600&display=swap"
      rel="stylesheet"
    />

    <ThemeInit />
  </head>
  <body
    class="min-h-screen bg-manila-light font-sans text-faded-black antialiased selection:bg-gold selection:text-faded-black dark:bg-faded-black dark:text-manila-light"
  >
    <div class="fixed top-4 right-4 z-50">
      <ThemeToggle client:idle />
    </div>
    <slot />
  </body>
</html>
