{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "isolatedModules": true
  },
  "include": ["fixtures/**/*.ts", "page-objects/**/*.ts", "tests/**/*.ts", "apps/**/*.ts", "apps/**/*.tsx"]
}
