{
  "bump-minor-pre-major": true,
  "bump-patch-for-minor-pre-major": false,
  "tag-separator": "@",
  "include-component-in-tag": true,
  "include-v-in-tag": false,
  "changelog-path": "CHANGELOG.md",
  "plugins": [
    {
      "type": "node-workspace",
      "merge": false
    },
    {
      "type": "linked-versions",
      "groupName": "videojs",
      "components": [
        "@videojs/core",
        "@videojs/element",
        "@videojs/html",
        "@videojs/icons",
        "@videojs/react",
        "@videojs/spf",
        "@videojs/store",
        "@videojs/utils"
      ]
    }
  ],
  "packages": {
    "packages/core": {
      "component": "@videojs/core",
      "prerelease": true,
      "prerelease-type": "beta",
      "versioning": "prerelease",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/element": {
      "component": "@videojs/element",
      "prerelease": true,
      "prerelease-type": "beta",
      "versioning": "prerelease",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/html": {
      "component": "@videojs/html",
      "prerelease": true,
      "prerelease-type": "beta",
      "versioning": "prerelease",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/icons": {
      "component": "@videojs/icons",
      "prerelease": true,
      "prerelease-type": "beta",
      "versioning": "prerelease",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/react": {
      "component": "@videojs/react",
      "prerelease": true,
      "prerelease-type": "beta",
      "versioning": "prerelease",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/spf": {
      "component": "@videojs/spf",
      "prerelease": true,
      "prerelease-type": "beta",
      "versioning": "prerelease",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/store": {
      "component": "@videojs/store",
      "prerelease": true,
      "prerelease-type": "beta",
      "versioning": "prerelease",
      "changelog-path": "CHANGELOG.md"
    },
    "packages/utils": {
      "component": "@videojs/utils",
      "prerelease": true,
      "prerelease-type": "beta",
      "versioning": "prerelease",
      "changelog-path": "CHANGELOG.md"
    }
  }
}
